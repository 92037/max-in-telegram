:root {
    --tg-bg: var(--tg-theme-bg-color, #ffffff);
    --tg-text: var(--tg-theme-text-color, #000000);
    --tg-hint: var(--tg-theme-hint-color, #999999);
    --tg-link: var(--tg-theme-link-color, #2481cc);
    --tg-button: var(--tg-theme-button-color, #2481cc);
    --tg-button-text: var(--tg-theme-button-text-color, #ffffff);
    --bubble-out: #effdde;
    --bubble-in: #ffffff;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    -webkit-tap-highlight-color: transparent;
}

body {
    background: var(--tg-bg);
    color: var(--tg-text);
    height: 100vh;
    overflow: hidden;
}

#app {
    height: 100vh;
    display: flex;
    flex-direction: column;
}

/* Header */
.header {
    background: var(--tg-bg);
    padding: 8px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 0.5px solid rgba(0,0,0,0.1);
    position: sticky;
    top: 0;
    z-index: 100;
}

.header-info {
    display: flex;
    align-items: center;
    gap: 12px;
}

.avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 18px;
}

.header-text h1 {
    font-size: 16px;
    font-weight: 600;
}

.status {
    font-size: 13px;
    color: var(--tg-hint);
}

.header-actions button {
    background: none;
    border: none;
    font-size: 20px;
    padding: 8px;
    cursor: pointer;
}

/* Screens */
.screen {
    display: none;
    flex: 1;
    overflow-y: auto;
}

.screen.active {
    display: block;
}

/* Chat List */
.chat-item {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    gap: 12px;
    cursor: pointer;
    transition: background 0.2s;
}

.chat-item:hover {
    background: rgba(0,0,0,0.05);
}

.chat-info {
    flex: 1;
    min-width: 0;
}

.chat-info h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 4px;
}

.chat-info p {
    font-size: 14px;
    color: var(--tg-hint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.time {
    font-size: 12px;
    color: var(--tg-hint);
    align-self: flex-start;
}

.badge {
    background: var(--tg-button);
    color: white;
    font-size: 12px;
    padding: 2px 6px;
    border-radius: 10px;
    margin-left: 4px;
}

/* Chat Screen */
.chat-header {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    gap: 12px;
    background: var(--tg-bg);
    border-bottom: 0.5px solid rgba(0,0,0,0.1);
}

.chat-header button {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
}

.chat-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
}

.messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><rect fill="%23f0f2f5" width="100" height="100"/></svg>');
}

.message {
    max-width: 80%;
    padding: 8px 12px;
    border-radius: 18px;
    position: relative;
    animation: slideIn 0.3s ease;
}

@keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.message.out {
    align-self: flex-end;
    background: var(--bubble-out);
    border-bottom-right-radius: 4px;
}

.message.in {
    align-self: flex-start;
    background: var(--bubble-in);
    border-bottom-left-radius: 4px;
    box-shadow: 0 1px 2px rgba(0,0,0,0.1);
}

.message-text {
    font-size: 15px;
    line-height: 1.4;
    word-wrap: break-word;
}

.message-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    margin-top: 4px;
    font-size: 11px;
    color: var(--tg-hint);
}

.message.self-destruct {
    border: 2px solid #ff6b6b;
}

.timer-badge {
    background: #ff6b6b;
    color: white;
    padding: 2px 6px;
    border-radius: 10px;
    font-size: 10px;
}

/* Voice message */
.voice-message {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 150px;
}

.voice-wave {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
}

.wave-bar {
    width: 3px;
    background: var(--tg-link);
    border-radius: 2px;
    animation: wave 1s ease infinite;
}

@keyframes wave {
    0%, 100% { height: 8px; }
    50% { height: 20px; }
}

/* Input Area */
.input-area {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    gap: 8px;
    background: var(--tg-bg);
    border-top: 0.5px solid rgba(0,0,0,0.1);
}

.input-area button {
    background: none;
    border: none;
    font-size: 24px;
    padding: 8px;
    cursor: pointer;
    color: var(--tg-hint);
}

#message-input {
    flex: 1;
    border: none;
    background: rgba(0,0,0,0.05);
    padding: 10px 16px;
    border-radius: 20px;
    font-size: 15px;
    outline: none;
}

#send-btn {
    color: var(--tg-button);
}

/* Modal */
.modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--tg-bg);
    padding: 20px;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3);
    z-index: 1000;
}

.modal.hidden {
    display: none;
}

.timer-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 16px;
}

.timer-options button {
    padding: 12px;
    border: none;
    background: var(--tg-button);
    color: var(--tg-button-text);
    border-radius: 8px;
    cursor: pointer;
}

/* E2E Encryption indicator */
.encrypted::after {
    content: "🔒";
    font-size: 10px;
    margin-left: 4px;
}

/* Troll elements */
.troll-banner {
    background: linear-gradient(90deg, #ff6b6b, #feca57);
    color: white;
    text-align: center;
    padding: 4px;
    font-size: 12px;
    font-weight: 600;
}

.max-logo {
    position: fixed;
    bottom: 80px;
    right: 16px;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
    animation: pulse 2s infinite;
    cursor: pointer;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

/* Responsive */
@media (max-width: 480px) {
    .message { max-width: 85%; }
}
