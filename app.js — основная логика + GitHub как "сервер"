// Навигация
function openChat(chatId) {
    currentChat = chatId;
    document.getElementById('chat-list').classList.remove('active');
    document.getElementById('chat-screen').classList.add('active');
    
    const names = {
        'saved': 'Избранное',
        'durov': 'Павел Дуров'
    };
    document.getElementById('current-chat-name').textContent = names[chatId] || 'Чат';
    
    loadChatMessages(chatId);
}

function backToList() {
    document.getElementById('chat-screen').classList.remove('active');
    document.getElementById('chat-list').classList.add('active');
    currentChat = null;
}

// Отправка сообщения
async function sendMessage() {
    const input = document.getElementById('message-input');
    const text = input.value.trim();
    if (!text) return;

    const message = {
        id: Date.now(),
        text: text,
        out: true,
        timestamp: new Date().toISOString(),
        encrypted: true,
        selfDestruct: selfDestructTimer,
        chatId: currentChat
    };

    // "Шифруем" (визуально)
    if (message.encrypted) {
        message.text = `🔒 ${text}`;
    }

    // Добавляем в UI
    renderMessage(message);
    
    // Сохраняем в localStorage (наша "база данных")
    saveMessage(message);
    
    // Если есть таймер самоуничтожения
    if (selfDestructTimer) {
        SelfDestruct.schedule(message.id, selfDestructTimer);
        selfDestructTimer = null;
    }

    // Отправляем в GitHub Issues (как бесплатный бэкенд)
    await syncToGitHub(message);

    input.value = '';
}

// Рендер сообщения
function renderMessage(msg) {
    const container = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = `message ${msg.out ? 'out' : 'in'} ${msg.selfDestruct ? 'self-destruct' : ''}`;
    div.id = `msg-${msg.id}`;
    
    let html = `<div class="message-text">${escapeHtml(msg.text)}</div>`;
    
    // Мета-информация
    html += `<div class="message-meta">`;
    html += formatTime(msg.timestamp);
    
    if (msg.encrypted) {
        html += ' <span class="encrypted"></span>';
    }
    
    if (msg.selfDestruct) {
        const remaining = SelfDestruct.getRemainingTime(msg.id);
        html += ` <span class="timer-badge">⏱️ ${remaining || msg.selfDestruct}s</span>`;
    }
    
    // Галочки как в Telegram
    html += msg.out ? ' <span>✓✓</span>' : '';
    html += `</div>`;
    
    div.innerHTML = html;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
}

// Голосовые сообщения
async function startVoice() {
    await voiceRecorder.start();
}

async function stopVoice() {
    const { blob, duration } = await voiceRecorder.stop();
    
    // Создаём визуализацию
    const waveform = voiceRecorder.generateWaveform();
    const barsHtml = waveform.map(h => 
        `<div class="wave-bar" style="height:${h}px"></div>`
    ).join('');
    
    const message = {
        id: Date.now(),
        type: 'voice',
        duration: duration,
        waveform: waveform,
        out: true,
        timestamp: new Date().toISOString()
    };
    
    renderVoiceMessage(message, barsHtml);
    saveMessage(message);
}

function renderVoiceMessage(msg, barsHtml) {
    const container = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = `message ${msg.out ? 'out' : 'in'}`;
    
    div.innerHTML = `
        <div class="voice-message">
            <button>▶️</button>
            <div class="voice-wave">${barsHtml}</div>
            <span>${msg.duration}"</span>
        </div>
        <div class="message-meta">${formatTime(msg.timestamp)} ✓✓</div>
    `;
    
    container.appendChild(div);
}

